# Values in this file will be overridden from .env.test.local, if it exists.
# (Note: no way for that file to *unset* values in this file; it can only set
# them to the empty string.)

SITE_PASSWORD=testtest
ADMIN_PASSWORD=admintest
AUTH_SECRET=test-only-do-not-use-in-production-7f4c8e2a1b9d6f3e
DATABASE_URL=file:./data.test.db
SB_UPLOADS_DIR=./uploads-test/
# Enables the dev fake clock (?dev=1 toolbar + time-override cookie) so its E2E
# test can time-travel. Inert for other tests, which never opt in.
SB_ENABLE_DEV_TOOLS=1

# Email tests are opt-in: they need Mailpit running (make mailpit) and these
# variables set in .env.test.local, otherwise they are skipped. See
# CONTRIBUTING.md § Running tests. Typical values:
#   MAILPIT_API_URL=http://localhost:8025
#   SMTP_URL=smtp://localhost:1025
#   SMTP_FROM='Test <mailer-test@test.example>'

# For e2e, playwright.config.ts always overwrites SITE_URL with the URL of the
# server it starts on a free port of its own.
SITE_URL=http://localhost:3000
